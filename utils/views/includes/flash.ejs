<% if (typeof successmsg !== 'undefined' && Array.isArray(successmsg) && successmsg.length) { %>
<div class="alert alert-success alert-dismissible fade show col-6 offset-3" role="alert">
  <%= successmsg[0] %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>

<% if (typeof errormsg !== 'undefined' && Array.isArray(errormsg) && errormsg.length) { %>
<div class="alert alert-danger alert-dismissible fade show col-6 offset-3" role="alert">
  <%= errormsg[0] %>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
<% } %>