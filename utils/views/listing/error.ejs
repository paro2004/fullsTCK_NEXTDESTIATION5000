<% layout("/layouts/boilerPlate") %>

<div class="error-shell">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 col-12">
            <div class="error-card">
                <div class="error-icon-wrapper mb-4">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <div class="text-center mb-4">
                    <h2 class="error-title">Error <%= statusCode %></h2>
                    <p class="error-message"><%= message %></p>
                </div>
                <div class="d-flex gap-3">
                    <a href="/listing" class="btn btn-primary w-100" style="background: linear-gradient(135deg, rgb(188, 44, 58), rgb(210, 50, 65)); border: none;">
                        <i class="fa-solid fa-home me-2"></i> Go to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

