<% layout("/layouts/boilerPlate") %>
<style>
    .filter {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin: 0;
        padding: 0.75rem 1.25rem;
        opacity: 0.8;
        text-align: center;
        color: inherit;
        text-decoration: none;
    }

    .filter:hover {
        opacity: 1;
        cursor: pointer;
    }

    .filter:hover p {
        font-weight: 700;
        text-decoration: underline;
        text-underline-offset: 0.25rem;
    }

    .filter i {
        font-size: 2rem;
        line-height: 1;
    }

    .filter p {
        margin: 0.35rem 0 0;
        font-size: 0.95rem;
    }

    .tax-toggle {
        position: absolute;
        right: 1rem;
        top: 5rem;
        margin-top: 0.75rem;
        margin-right: 0.75rem;
        border: 1px solid rgba(0,0,0,0.12);
        border-radius: 1rem;
        height: 3.5rem;
        padding: 0.5rem 0.9rem;
        background: #fff;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }

    .tax-toggle .form-check {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0;
    }

    .tax-toggle .form-check-label {
        margin: 0;
        white-space: nowrap;
    }

    #filters {
        display: flex;
        flex-direction: row;
        flex-wrap: nowrap;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        width: 100%;
        max-width: 980px;
        margin: 1.25rem auto 0;
        overflow-x: auto;
    }

    .tax-info{
        display: none;
        margin-left: 0.5rem;
        color: #28a745;
    }

    /* Custom toggle/switch styling */
    .form-switch .form-check-input {
        -webkit-appearance: none;
        appearance: none;
        width: 44px;
        height: 24px;
        background: #e9ecef;
        border-radius: 999px;
        position: relative;
        cursor: pointer;
        transition: background 0.18s ease-in-out;
        box-shadow: inset 0 0 0 1px rgba(0,0,0,0.03);
        display: inline-block;
        vertical-align: middle;
    }

    .form-switch .form-check-input::after {
        content: "";
        position: absolute;
        top: 3px;
        left: 3px;
        width: 18px;
        height: 18px;
        background: #fff;
        border-radius: 50%;
        box-shadow: 0 2px 6px rgba(0,0,0,0.12);
        transition: transform 0.18s ease-in-out;
    }

    .form-switch .form-check-input:checked {
        background: #4CAF50;
    }

    .form-switch .form-check-input:checked::after {
        transform: translateX(20px);
    }

    .form-switch .form-check-label {
        font-weight: 500;
        color: #222;
        margin-left: 0.25rem;
    }
</style>
<body>
    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault"> Display total with taxes</label>
        </div>
    </div>

    <div id = "filters">
        <a class = "filter" href="/listing/category/mountain">
           <div><i class="fa-solid fa-mountain-sun"></i></div>
           <p> Mountain </p>
        </a>

        <a class = "filter" href="/listing/category/sea-side">
           <div><i class="fa-solid fa-umbrella-beach"></i></div>
           <p> Sea Side </p>
        </a>

        <a class = "filter" href="/listing/category/forest">
           <div><i class="fa-solid fa-tree"></i></div>
           <p> Forest </p>
        </a>

        <a class = "filter" href="/listing/category/farm-house">
           <div><i class="fa-solid fa-cow"></i></div>
           <p> Farm House</p>
        </a>

        <a class = "filter" href="/listing/category/trending">
           <div><i class="fa-solid fa-fire"></i></div>
           <p> Trending </p>
        </a>

        <a class = "filter" href="/listing/category/experience">
           <div><i class="fa-solid fa-rocket"></i></div>
           <p> Experience </p>
        </a>

        <a class = "filter" href="/listing/category/services">
           <div><i class="fa-solid fa-bell-concierge"></i></div>
           <p> Services </p>
        </a>
    </div>

    <!-- <form method = "GET" action = "/listing/new">
        <button>Create New Listig</button>
    </form> -->

  <div class="container px-3 mt-3">
    <div class="row g-3">

        <% for(let listing of allListing){ %>
            <% const listingImageUrl = typeof listing.image === 'string' 
                ? (listing.image.match(/url\s*[:=]\s*['"]([^'"]+)['"]/) ? listing.image.match(/url\s*[:=]\s*['"]([^'"]+)['"]/)[1] : listing.image)
                : listing.image?.url || '' %>
            <div class="col-lg-4 col-md-6 col-sm-12 mb-4 px-2 py-2">

                <a href="/listing/<%= listing._id %>" class="listing-link">

                    <div class="card h-100">

                        <img 
                            src="<%= listingImageUrl %>" 
                            class="card-img-top"
                            alt="listing-image"
                            onerror="this.src='https://images.pexels.com/photos/28408505/pexels-photo-28408505.jpeg'"
                        >

                    
                        <div class="card-img-overlay">
                            <h5 class="card-title"></h5>
                            <p class="card-text"></p>
                        </div>

                        <div class="card-body">

                            <p class="card-text">

                                <b><%= listing.title %></b>

                                <br>

                                <span class="price">
                                    &#8377;<%= listing.price.toLocaleString("en-IN") %> / night
                                </span>
                                <i class="tax-info"> +18% GST</i>

                            </p>

                        </div>

                    </div>

                </a>

            </div>

        <% } %>

    </div>
</div>

</body>

<script>
    const taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("change", () => {
        const taxInfo = document.getElementsByClassName("tax-info");
        for (const info of taxInfo) {
            info.style.display = info.style.display === "inline" ? "none" : "inline";
        }
    });
</script>
